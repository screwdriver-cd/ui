<BsModal
  id="confirm-action-modal"
  @onHide={{fn @closeModal}}
  as |modal|
>
  <modal.header>
    <div class="modal-title">Are you sure you want to {{@action}}?</div>
  </modal.header>
  <modal.body>
    {{#if this.errorMessage}}
      <InfoMessage
        id="confirm-action-error"
        @message={{this.errorMessage}}
        @type="warning"
        @icon="triangle-exclamation"
        @dismissible={{false}}
      />
    {{/if}}

    {{#if this.isNotLatestCommit}}
      <div
        id="not-latest-warning"
        class="alert alert-warning"
      >
        <FaIcon @icon="triangle-exclamation" />
        This is <strong> NOT </strong> the latest commit.
      </div>
    {{/if}}
    {{#if this.notice}}
      <div
        id="user-notice"
        class="alert alert-warning"
      >
        <FaIcon @icon="triangle-exclamation" />
        {{this.notice}}
      </div>
    {{/if}}

    {{#if @stage}}
      <div id="confirm-action-stage">Stage: <code>{{@stage.name}}</code></div>
    {{else}}
      <div id="confirm-action-job">Job: <code>{{this.jobName}}</code></div>
    {{/if}}

    {{#if @event}}
      <div id="confirm-action-commit">
        Commit: <code>{{this.truncatedMessage}}</code>
        <a
          id="confirm-action-commit-link"
          class={{if this.isLatestCommitEvent "latest-commit"}}
          href={{this.commitUrl}}
        >
          #{{this.truncatedSha}}
        </a>
      </div>
    {{/if}}

    <div id="confirm-action-parent-event">
      Parent event:
      {{#if (and @event.id this.isRestartAction)}}
        <code>{{@event.id}}</code>
      {{else}}
        <span class="no-parent-event">None</span>
        <BsTooltip
          @placement="right"
          @triggerElement=".no-parent-event"
          @renderInPlace={{true}}
          @delayHide="100"
          class="danger-tooltip"
        >
          This run will NOT inherit metadata or build statuses from parent event.
        </BsTooltip>
      {{/if}}
    </div>

    {{#if this.isFrozen}}
      <div class="frozen-reason">
        <label>
          <div>Reason:</div>
          <Input
            @type="text"
            @value={{this.reason}}
            placeholder="Please enter a reason"
          />
        </label>
      </div>
    {{/if}}

    {{#if this.isParameterized}}
      <Pipeline::Parameters
        @action={{@action}}
        @pipelineParameters={{this.defaultPipelineParameters}}
        @jobParameters={{this.defaultJobParameters}}
        @job={{@job}}
        @event={{@event}}
        @onUpdateParameters={{this.onUpdateParameters}}
      />
    {{else}}
      <div class="no-parameters-title">
        NO PARAMETERS TO CONFIGURE
      </div>
    {{/if}}
  </modal.body>
  <modal.footer>
    <BsButton
      id="submit-action"
      disabled={{if this.isNotFoundError false this.isSubmitButtonDisabled}}
      @type="primary"
      @defaultText={{if this.isNotFoundError "Close" "Yes"}}
      @pendingText={{unless this.isNotFoundError this.pendingAction}}
      @onClick={{if this.isNotFoundError (fn @closeModal) (fn this.startBuild)}}
    />
  </modal.footer>
</BsModal>
